STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
RESEND_API_KEY=re_...
ANTHROPIC_API_KEY=sk-ant-...
FROM_EMAIL=readings@cardblueprints.com
BASE_URL=https://cardblueprints.com
SUCCESS_URL=https://cardblueprints.com/thank-you
CANCEL_URL=https://cardblueprints.com
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
# Or provide the entire JSON as a single-line env var instead of a file path
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=
# "customer" shares the reading doc directly to the buyer email, "public" creates an anyone-with-link doc
GOOGLE_DOC_SHARE_MODE=customer
# If Google Doc creation fails, fall back to the old inline email body
GOOGLE_DOC_FALLBACK_INLINE=true
